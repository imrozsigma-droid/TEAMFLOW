# ═══════════════════════════════════════════
# teamflow — Environment Configuration
# Generated by Backend Factory
# ═══════════════════════════════════════════

# ─── Server ────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ──────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Database (Direct Connection) ─────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Auth ──────────────────────────────────
JWT_SECRET=your-jwt-secret-here
# Get from: Supabase Dashboard → Project Settings → API → JWT Secret

# ─── Webhooks ──────────────────────────────
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BACKOFF_MS=1000

# ─── Rate Limiting ─────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ──────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

DB_POOL_MAX=20
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.com
# SendGrid -> Settings -> API Keys (starts with SG.)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx.yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
# Mailgun -> API Security -> Private API key
MAILGUN_API_KEY=your-mailgun-api-key
# Mailgun -> Sending -> Domains — your verified sending domain
MAILGUN_DOMAIN=mg.yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=no-reply@example.com
PIN_MAX_ATTEMPTS=3
PIN_LOCKOUT_MINS=5
PIN_EXPIRES_MINUTES=30
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=30
# AWS Console -> IAM -> Users -> Security credentials -> Access keys (starts with AKIA, 20 chars)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# Shown ONCE when the access key is created — 40 chars, keep secret
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Region of the Lambda function this backend invokes
AWS_LAMBDA_REGION=us-east-1
# AWS Console -> Lambda -> Functions -> function name (or full ARN)
AWS_LAMBDA_FUNCTION_NAME=your-function-name
AWS_S3_REGION=us-east-1
# AWS Console -> S3 -> your bucket name (must already exist in AWS_S3_REGION)
AWS_S3_BUCKET=your-bucket-name
# Region where your SES identities are verified
AWS_SES_REGION=us-east-1
# AWS Console -> SES -> Verified identities — sender must be verified (sandbox also requires verified recipients)
AWS_SES_FROM_EMAIL=no-reply@yourdomain.com
# Optional: SES configuration set for delivery tracking — leave empty to skip
AWS_SES_CONFIGURATION_SET=
LOG_LEVEL=info
SLOW_QUERY_MS=500